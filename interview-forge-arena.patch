+function clamp(value: number) {
+  return Math.max(0, Math.min(100, value))
+}
+
+function applyEffect(metrics: Metrics, effect: ActionEffect): Metrics {
+  return {
+    latency: clamp(metrics.latency + (effect.latency ?? 0)),
+    reliability: clamp(metrics.reliability + (effect.reliability ?? 0)),
+    cost: clamp(metrics.cost + (effect.cost ?? 0)),
+    confidence: clamp(metrics.confidence + (effect.confidence ?? 0)),
+  }
+}
+
+function getHealthLabel(value: number) {
+  if (value >= 80) return 'Strong'
+  if (value >= 60) return 'Stable'
+  if (value >= 40) return 'Shaky'
+  return 'Critical'
+}
