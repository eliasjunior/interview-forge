{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "interview-mcp (dev)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--prefix", "interview-mcp"],
      "port": 3000
    },
    {
      "name": "interview-mcp (start)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "start", "--prefix", "interview-mcp"],
      "port": 3000
    },
    {
      "name": "neural-map (dev)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev:ui", "--prefix", "interview-mcp"],
      "port": 3001
    },
    {
      "name": "interview-http",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev:http", "--prefix", "interview-mcp"],
      "port": 3001,
      "autoPort": false
    },
    {
      "name": "ui",
      "runtimeExecutable": "/bin/zsh",
      "runtimeArgs": ["-c", "source ~/.nvm/nvm.sh && npm run dev --prefix ui"],
      "port": 5173
    }
  ]
}
